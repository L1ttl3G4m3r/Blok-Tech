<!DOCTYPE html>
<html>
<head>
    <title>Tattoo AR Preview</title>
    <script src="https://aframe.io/releases/1.2.0/aframe.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/ar.js@2.1.7/aframe/build/aframe-ar.js"></script>
    <style>
        .arjs-loader {
            height: 100%;
            width: 100%;
            position: absolute;
            top: 0;
            left: 0;
            background-color: rgba(0, 0, 0, 0.8);
            z-index: 9999;
            display: flex;
            justify-content: center;
            align-items: center;
            color: white;
        }
    </style>
</head>
<body style="margin : 0px; overflow: hidden;">
    <div class="arjs-loader">
        Loading, please wait...
    </div>
    <a-scene embedded arjs="sourceType: webcam; debugUIEnabled: false; trackingMethod: best;">
        <a-marker preset="hiro">
            <a-entity
                geometry="primitive: plane; width: 0.5; height: 0.5;"
                material="src: url(<%= imageUrl %>); side: double"
                rotation="-90 0 0">
            </a-entity>
        </a-marker>
        <a-entity camera></a-entity>
    </a-scene>

    <script>
        window.onload = () => {
            const arjsLoader = document.querySelector('.arjs-loader');
            arjsLoader.remove();
        }
    </script>
</body>
</html>